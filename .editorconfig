# ============================================================
# Orion AeroDesign - Configuração básica de edição
# ============================================================
# Define regras gerais de formatação para manter consistência
# entre diferentes editores, sistemas operacionais e projetos.
# Regras específicas podem ser adicionadas conforme a tecnologia.
# ============================================================

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{java,cs}]
indent_size = 4

[Makefile]
indent_style = tab
